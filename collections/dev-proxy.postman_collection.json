  "info": {
    "_postman_id": "444cc8d6-5815-4784-ba3b-1786a45706e5",
    "name": "Microsoft Dev Proxy — Proxy API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "Dev Proxy is a Microsoft command-line API simulator. While running, it exposes a\nlocal HTTP control API on a port configured in the proxy settings (default 8897)\nso callers can inspect proxy state, toggle recording, generate JWTs, raise mock\nrequests, fetch the root certificate, and shut the proxy down programmatically.\n\n\nContact Support:\n Name: Microsoft Dev Proxy",
      "type": "text/plain"
    }
  }
